# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.
#
# NOTE: the public Firebase client config (apiKey, authDomain, etc.) is
# hardcoded directly in lib/firebase.ts — those values are safe to hardcode
# since they're already visible in the browser on any live Firebase web app.
# Only the genuinely secret Admin SDK credentials need to be set here.

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ADMIN_EMAIL=

# Web Push (VAPID) — needed for server-sent push notifications to actually
# go out (deal accepted/funded/delivered/released/refunded/disputed, etc.,
# via sendPushToUser in app/api/_lib/push.js). The PUBLIC key is also
# hardcoded client-side in lib/push.ts (VAPID_PUBLIC_KEY) — same value,
# both places, or the browser rejects the subscription. Generate a pair
# with `npx web-push generate-vapid-keys` and keep them consistent across
# environments (rotating either key invalidates every existing browser
# subscription).
VAPID_PUBLIC_KEY=
VAPID_SECRET=
VAPID_SUBJECT=
