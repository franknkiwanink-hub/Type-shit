# Server-side only (used by app/api/account, NOT exposed to the browser).
# These are Firebase Admin SDK credentials from your service account JSON —
# genuinely secret, must stay as env vars, never hardcoded in source.
#
# Copy these from your OLD Vercel project's Settings > Environment Variables
# (same values, that deployment already has them working).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ADMIN_EMAIL=
